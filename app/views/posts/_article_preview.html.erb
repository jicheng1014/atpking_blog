<%# @param post [Post] 要显示的文章对象 %>
<article class="group py-4 border-b border-stone-100 last:border-0">
  <div class="flex gap-4 sm:gap-6">

    <%# 日期列（桌面端） %>
    <div class="hidden sm:block text-xs text-stone-300 tabular-nums pt-1 w-12 shrink-0 text-right">
      <%= post.created_at.strftime("%m/%d") %>
    </div>

    <%# 正文区 %>
    <div class="flex-1 min-w-0">
      <h2 class="text-sm font-medium text-stone-800 leading-snug mb-1.5">
        <%= link_to post.title, post_path(post),
              class: "hover:text-amber-700 transition-colors duration-150" %>
      </h2>

      <p class="text-xs text-stone-400 leading-relaxed mb-2 line-clamp-2">
        <%= truncate(strip_tags(post.rendered_content), length: 100) %>
      </p>

      <div class="flex items-center gap-3 flex-wrap">
        <%# 移动端显示日期 %>
        <span class="sm:hidden text-xs text-stone-300 tabular-nums">
          <%= post.created_at.strftime("%m/%d") %>
        </span>

        <%# Tags %>
        <% post.tags.each do |tag| %>
          <%= link_to tag.name, tag_posts_path(tag: tag.slug),
                class: "text-xs px-2 py-0.5 bg-amber-50 text-amber-600 hover:bg-amber-100 rounded border border-amber-100 transition-colors" %>
        <% end %>
      </div>
    </div>

  </div>
</article>
