<%= content_for :styles do %>
  <%= stylesheet_link_tag "posts", "data-turbo-track": "reload" %>
<% end %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">

  <%# 顶部操作栏 %>
  <div class="flex items-center justify-between mb-10">
    <%= link_to root_path, class: "inline-flex items-center gap-1 text-xs text-stone-400 hover:text-stone-700 transition-colors" do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      返回
    <% end %>

    <% if current_user && @post.user_id == current_user.id %>
      <div class="flex items-center gap-3">
        <span class="text-xs <%= @post.published? ? 'text-emerald-500' : 'text-amber-500' %>">
          <%= @post.published? ? '已发布' : '草稿' %>
        </span>
        <%= link_to edit_admin_post_path(@post),
              class: "text-xs text-stone-400 hover:text-stone-700 transition-colors border border-stone-200 px-2.5 py-1 rounded-full" do %>
          编辑
        <% end %>
      </div>
    <% end %>
  </div>

  <%# 文章头部 %>
  <header class="mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-stone-900 leading-tight tracking-tight mb-4">
      <%= @post.title %>
    </h1>

    <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
      <time class="text-xs text-stone-400 tabular-nums" datetime="<%= @post.created_at.iso8601 %>">
        <%= @post.created_at.strftime("%Y年%m月%d日") %>
      </time>

      <% if @post.tags.any? %>
        <span class="text-stone-200 text-xs">|</span>
        <div class="flex flex-wrap gap-1.5">
          <% @post.tags.each do |tag| %>
            <%= link_to tag.name, tag_posts_path(tag: tag.slug),
                  class: "text-xs px-2 py-0.5 bg-amber-50 text-amber-600 hover:bg-amber-100 rounded border border-amber-100 transition-colors" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </header>

  <%# 正文 %>
  <div class="prose prose-stone prose-sm sm:prose max-w-none
              prose-headings:font-semibold prose-headings:text-stone-800
              prose-a:text-amber-700 prose-a:no-underline hover:prose-a:underline
              prose-blockquote:border-amber-300 prose-blockquote:text-stone-500
              prose-code:text-stone-700 prose-code:bg-stone-100 prose-code:px-1 prose-code:rounded prose-code:text-sm prose-code:before:content-none prose-code:after:content-none">
    <%= raw @post.rendered_content %>

    <% if Setting.post_signature.present? %>
      <div class="mt-10 pt-6 border-t border-stone-100 text-xs text-stone-400 font-light not-prose">
        <%= raw Setting.post_signature %>
      </div>
    <% end %>
  </div>

  <%# 底部导航 %>
  <div class="mt-12 pt-6 border-t border-stone-100 flex items-center justify-between">
    <%= link_to root_path, class: "text-xs text-stone-400 hover:text-stone-700 transition-colors" do %>
      ← 所有文章
    <% end %>
    <a href="#" class="text-xs text-stone-300 hover:text-stone-500 transition-colors">↑ 回到顶部</a>
  </div>

  <%# 评论区 %>
  <% if @comments.any? || current_user %>
    <section class="mt-12">
      <h2 class="text-sm font-medium text-stone-700 mb-6">
        评论
        <% if @comments.any? %>
          <span class="text-stone-300 font-normal ml-1"><%= @comments.size %></span>
        <% end %>
      </h2>

      <%# 已有评论 %>
      <% if @comments.any? %>
        <div class="space-y-5 mb-8">
          <% @comments.each do |comment| %>
            <div class="flex gap-3 group">
              <div class="w-6 h-6 rounded-full bg-stone-200 flex items-center justify-center shrink-0 mt-0.5">
                <span class="text-xs text-stone-500 font-medium"><%= comment.user.nick_name.first.upcase %></span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline gap-2 mb-1">
                  <span class="text-xs font-medium text-stone-700"><%= comment.user.nick_name %></span>
                  <time class="text-xs text-stone-300 tabular-nums"><%= comment.created_at.strftime("%Y-%m-%d") %></time>
                  <% if current_user && (comment.user_id == current_user.id || @post.user_id == current_user.id) %>
                    <%= button_to post_comment_path(@post, comment), method: :delete,
                          class: "ml-auto opacity-0 group-hover:opacity-100 text-xs text-stone-300 hover:text-red-400 transition-all" do %>
                      删除
                    <% end %>
                  <% end %>
                </div>
                <p class="text-sm text-stone-600 leading-relaxed"><%= comment.content %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# 发评论表单（仅登录可见）%>
      <% if current_user %>
        <%= form_with url: post_comments_path(@post), model: @comment, local: true, class: "mt-6" do |f| %>
          <%= f.text_area :content, rows: 3,
                placeholder: "写下你的想法...",
                class: "w-full text-sm text-stone-700 bg-stone-50 border border-stone-200 rounded-lg px-4 py-3 resize-none focus:outline-none focus:ring-1 focus:ring-amber-300 focus:border-amber-300 placeholder-stone-300 transition" %>
          <div class="flex justify-end mt-2">
            <%= f.submit "发表评论",
                  class: "text-xs px-4 py-2 bg-stone-800 text-white rounded-full hover:bg-stone-700 cursor-pointer transition-colors" %>
          </div>
        <% end %>
      <% else %>
        <p class="text-xs text-stone-400">
          <%= link_to '登录', new_session_path, class: "text-amber-600 hover:underline" %> 后可以发表评论
        </p>
      <% end %>
    </section>
  <% end %>

</div>
