<!-- 导航栏 -->
<nav class="sticky top-0 z-10 bg-stone-50/80 backdrop-blur-sm border-b border-stone-200" data-controller="mobile-menu">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-14">

      <!-- Logo -->
      <%= link_to root_path, class: "flex items-center gap-2 group" do %>
        <%= image_tag "logo.jpeg", class: "h-5 w-5 rounded-full object-cover", alt: "Logo" %>
        <span class="text-sm font-semibold text-stone-800 group-hover:text-stone-500 transition-colors">
          <%= Setting.site_name.presence || '3Q RUOK?' %>
        </span>
      <% end %>

      <!-- 桌面端导航 -->
      <div class="hidden sm:flex items-center gap-6">
        <%= link_to '文章', root_path, class: nav_link_class(controller_name == 'posts' || (controller_name == 'tags' && action_name == 'show')) %>
        <%= link_to '标签', tags_path, class: nav_link_class(controller_name == 'tags' && action_name == 'index') %>
        <% if current_user %>
          <%= link_to '管理', admin_root_path, class: "text-xs text-stone-400 hover:text-stone-600 transition-colors border border-stone-200 px-2.5 py-1 rounded-full" %>
        <% end %>
      </div>

      <!-- 移动端菜单按钮 -->
      <button type="button"
              class="sm:hidden p-1.5 text-stone-500 rounded-md hover:bg-stone-100 transition-colors"
              data-action="click->mobile-menu#toggle">
        <span class="sr-only">打开菜单</span>
        <svg class="w-5 h-5" data-mobile-menu-target="openIcon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg class="hidden w-5 h-5" data-mobile-menu-target="closeIcon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

    </div>
  </div>

  <!-- 移动端菜单面板 -->
  <div class="hidden sm:hidden border-t border-stone-200" data-mobile-menu-target="panel">
    <div class="max-w-2xl mx-auto px-4 py-3 space-y-0.5">
      <%= link_to '文章', root_path, class: mobile_nav_link_class(controller_name == 'posts') %>
      <%= link_to '标签', tags_path, class: mobile_nav_link_class(controller_name == 'tags') %>
      <% if current_user %>
        <%= link_to '管理文章', admin_root_path, class: mobile_nav_link_class(false) %>
        <div class="px-3 py-2 text-xs text-stone-400 border-t border-stone-100 mt-1 pt-3"><%= current_user.email %></div>
        <%= button_to '退出登录', session_path, method: :delete,
            class: "w-full text-left px-3 py-2 text-sm text-stone-500 hover:text-stone-800 hover:bg-stone-100 rounded-md transition-colors" %>
      <% end %>
    </div>
  </div>
</nav>
