<div class="min-h-[calc(100vh-8rem)] flex flex-col items-center justify-center px-4 py-10">
  <div class="w-full max-w-sm">

    <%# Logo / Brand %>
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-flex flex-col items-center gap-3" do %>
        <%= image_tag "logo.jpeg", class: "h-12 w-12 rounded-full object-cover shadow-sm", alt: "Logo" %>
        <span class="text-lg font-semibold text-stone-800">
          <%= Setting.site_name.presence || '3Q RUOK?' %>
        </span>
      <% end %>
      <p class="mt-1.5 text-sm text-stone-400">管理员登录</p>
    </div>

    <%# Flash %>
    <% if alert = flash[:alert] %>
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-100 rounded-lg text-sm text-red-600">
        <%= alert %>
      </div>
    <% end %>

    <%# 表单卡片 %>
    <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6">
      <%= form_with url: session_url do |form| %>
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-medium text-stone-500 mb-1.5">邮箱</label>
            <%= form.email_field :email_address,
                  required: true,
                  autofocus: true,
                  autocomplete: "username",
                  placeholder: "your@email.com",
                  value: params[:email_address],
                  class: "block w-full rounded-lg border border-stone-200 px-3 py-2.5 text-base text-stone-800 placeholder-stone-300 focus:outline-none focus:border-stone-400 focus:ring-1 focus:ring-stone-400 transition-colors" %>
          </div>

          <div>
            <label class="block text-xs font-medium text-stone-500 mb-1.5">密码</label>
            <%= form.password_field :password,
                  required: true,
                  autocomplete: "current-password",
                  placeholder: "••••••••",
                  maxlength: 72,
                  class: "block w-full rounded-lg border border-stone-200 px-3 py-2.5 text-base text-stone-800 placeholder-stone-300 focus:outline-none focus:border-stone-400 focus:ring-1 focus:ring-stone-400 transition-colors" %>
          </div>
        </div>

        <div class="mt-6">
          <%= form.submit "登录",
                class: "w-full py-2.5 bg-stone-800 hover:bg-stone-700 text-white text-sm font-medium rounded-lg cursor-pointer transition-colors" %>
        </div>

        <div class="mt-4 text-center">
          <%= link_to "忘记密码?", new_password_path,
                class: "text-xs text-stone-400 hover:text-stone-600 transition-colors" %>
        </div>
      <% end %>
    </div>

  </div>
</div>
