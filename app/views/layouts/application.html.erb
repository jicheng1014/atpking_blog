<!DOCTYPE html>
<html class="h-full bg-stone-50">
  <head>
    <%= render 'shared/google_analytics' %>
    <title><%= Setting.site_name.presence || 'My Blog' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= auto_discovery_link_tag :rss, feed_posts_url(format: :rss), title: "RSS Feed" %>

    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <!-- Favicons -->
    <%= favicon_link_tag 'favicons/favicon-16x16.png', sizes: '16x16', type: 'image/png' %>
    <%= favicon_link_tag 'favicons/favicon-32x32.png', sizes: '32x32', type: 'image/png' %>
    <%= favicon_link_tag 'favicons/apple-touch-icon.png', rel: 'apple-touch-icon', type: 'image/png' %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :styles %>
  </head>

  <body class="h-full antialiased text-stone-800">
    <%= render 'shared/navbar' %>

    <% if notice %>
      <div class="max-w-2xl mx-auto px-4 sm:px-6 mt-4">
        <div class="px-4 py-3 text-sm text-emerald-700 bg-emerald-50 rounded-lg border border-emerald-100">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-2xl mx-auto px-4 sm:px-6 mt-4">
        <div class="px-4 py-3 text-sm text-red-700 bg-red-50 rounded-lg border border-red-100">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <footer class="mt-16 pb-10 text-center text-stone-400 text-xs">
      <% if Setting.icp_number.present? %>
        <div><%= Setting.icp_number %></div>
      <% end %>
    </footer>
  </body>
</html>
