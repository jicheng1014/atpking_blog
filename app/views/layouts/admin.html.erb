<!DOCTYPE html>
<html class="h-full bg-stone-50">
  <head>
    <title>管理 · <%= Setting.site_name.presence || 'My Blog' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :styles %>
  </head>

  <body class="h-full antialiased text-stone-800">

    <nav class="sticky top-0 z-10 bg-stone-50/80 backdrop-blur-sm border-b border-stone-200">
      <div class="max-w-4xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">

          <div class="flex items-center gap-6">
            <%= link_to admin_root_path, class: "flex items-center gap-1.5 group" do %>
              <span class="text-sm font-semibold text-stone-700 group-hover:text-stone-500 transition-colors">
                <%= Setting.site_name.presence || '3Q RUOK?' %>
              </span>
              <span class="text-stone-300 text-sm">/</span>
              <span class="text-xs text-stone-400">管理</span>
            <% end %>

            <div class="hidden sm:flex items-center gap-5">
              <%= link_to '文章', admin_posts_path,
                    class: "text-sm transition-colors #{controller_name == 'posts' ? 'text-stone-900 font-medium' : 'text-stone-400 hover:text-stone-700'}" %>
              <%= link_to '设置', admin_settings_path,
                    class: "text-sm transition-colors #{controller_name == 'settings' ? 'text-stone-900 font-medium' : 'text-stone-400 hover:text-stone-700'}" %>
              <%= link_to '队列', admin_mission_control_jobs_path,
                    class: "text-sm text-stone-400 hover:text-stone-700 transition-colors" %>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <span class="hidden sm:block text-xs text-stone-300"><%= current_user&.email %></span>
            <%= link_to '查看网站', root_path, target: '_blank',
                  class: "text-xs text-stone-400 hover:text-stone-700 transition-colors border border-stone-200 px-2.5 py-1 rounded-full" %>
            <%= button_to '退出', session_path, method: :delete,
                  class: "text-xs text-stone-400 hover:text-red-400 transition-colors cursor-pointer" %>
          </div>

        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-4">
        <div class="px-4 py-3 text-sm text-emerald-700 bg-emerald-50 rounded-lg border border-emerald-100">
          <%= notice %>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-4">
        <div class="px-4 py-3 text-sm text-red-700 bg-red-50 rounded-lg border border-red-100">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

  </body>
</html>
