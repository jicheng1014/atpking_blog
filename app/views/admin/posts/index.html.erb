<div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">

  <div class="flex items-center justify-between mb-8">
    <h1 class="text-base font-semibold text-stone-800">文章</h1>
    <%= link_to '+ 写新文章', new_admin_post_path,
          class: "text-xs px-3 py-1.5 bg-stone-800 text-white rounded-full hover:bg-stone-700 transition-colors" %>
  </div>

  <% if @posts.empty? %>
    <div class="text-sm text-stone-400 text-center py-20">还没有文章，开始写第一篇吧</div>
  <% else %>
    <%# 按年份分组 %>
    <% @posts.group_by { |p| p.created_at.year }.each do |year, year_posts| %>
      <div class="flex items-center gap-3 mb-2 mt-8 first:mt-0">
        <span class="text-xs font-medium text-stone-400 tabular-nums"><%= year %></span>
        <div class="flex-1 h-px bg-stone-200"></div>
      </div>

      <% year_posts.each do |post| %>
        <div class="group flex items-start gap-4 sm:gap-6 py-3.5 border-b border-stone-100 last:border-0">

          <%# 日期 %>
          <div class="hidden sm:block text-xs text-stone-300 tabular-nums pt-0.5 w-12 shrink-0 text-right">
            <%= post.created_at.strftime("%m/%d") %>
          </div>

          <%# 内容 %>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <span class="text-sm font-medium text-stone-800 leading-snug">
                  <%= link_to post.title, post_path(post), target: '_blank',
                        class: "hover:text-amber-700 transition-colors" %>
                </span>
                <% if post.tags.any? %>
                  <span class="ml-2 text-xs text-stone-300"><%= post.tags.map(&:name).join(' · ') %></span>
                <% end %>
              </div>

              <%# 状态 + 操作（hover 显示） %>
              <div class="flex items-center gap-3 shrink-0">
                <span class="text-xs <%= post.published? ? 'text-emerald-500' : 'text-amber-400' %>">
                  <%= post.published? ? '已发布' : '草稿' %>
                </span>
                <div class="opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-2">
                  <%= link_to '编辑', edit_admin_post_path(post),
                        class: "text-xs text-stone-400 hover:text-stone-700 transition-colors" %>
                  <%= button_to '删除', admin_post_path(post), method: :delete,
                        class: "text-xs text-stone-300 hover:text-red-400 transition-colors cursor-pointer",
                        form: { data: { turbo_confirm: '确定删除《' + post.title + '》？' } } %>
                </div>
              </div>
            </div>

            <div class="sm:hidden text-xs text-stone-300 mt-0.5 tabular-nums">
              <%= post.created_at.strftime("%m/%d") %>
            </div>
          </div>

        </div>
      <% end %>
    <% end %>
  <% end %>

</div>
