<div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">

  <h1 class="text-base font-semibold text-stone-800 mb-8">网站设置</h1>

  <%= form_with url: admin_settings_update_path, method: :patch, class: "space-y-6 max-w-xl" do |f| %>

    <div>
      <%= f.label :site_name, "站点名称", class: "block text-xs text-stone-400 mb-1.5" %>
      <%= f.text_field :site_name, value: @site_name,
            class: "w-full text-sm bg-stone-50 border border-stone-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-1 focus:ring-amber-300 focus:border-amber-300 transition" %>
    </div>

    <div>
      <%= f.label :icp_number, "备案号", class: "block text-xs text-stone-400 mb-1.5" %>
      <%= f.text_field :icp_number, value: @icp_number,
            placeholder: "粤ICP备XXXXXXXX号",
            class: "w-full text-sm bg-stone-50 border border-stone-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-1 focus:ring-amber-300 focus:border-amber-300 transition" %>
    </div>

    <div>
      <%= f.label :post_signature, "文章签名", class: "block text-xs text-stone-400 mb-1.5" %>
      <%= f.text_area :post_signature, value: @post_signature, rows: 4,
            class: "w-full text-sm bg-stone-50 border border-stone-200 rounded-lg px-3 py-2 focus:outline-none focus:ring-1 focus:ring-amber-300 focus:border-amber-300 transition resize-none" %>
      <p class="mt-1.5 text-xs text-stone-400">显示在每篇文章结尾，支持 HTML</p>
    </div>

    <div class="flex justify-end pt-2">
      <%= f.submit "保存设置",
            class: "text-sm px-5 py-2 bg-stone-800 text-white rounded-full hover:bg-stone-700 cursor-pointer transition-colors" %>
    </div>

  <% end %>
</div>
