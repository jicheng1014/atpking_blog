<div class="max-w-4xl mx-auto px-4 sm:px-6 py-10">

  <div class="flex items-center justify-between mb-8">
    <h1 class="text-base font-semibold text-stone-800">编辑灵感</h1>
    <%= link_to '← 返回', admin_thoughts_path,
          class: "text-xs text-stone-400 hover:text-stone-600 transition-colors" %>
  </div>

  <%= form_with(model: [:admin, @thought], class: "space-y-5", data: { controller: "paste-image" }) do |f| %>
    <% if @thought.errors.any? %>
      <div class="px-4 py-3 text-sm text-red-600 bg-red-50 rounded-lg border border-red-100">
        <% @thought.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div class="border border-stone-200 rounded-lg overflow-hidden bg-white">
      <%= f.text_area :content,
            rows: 6,
            class: "w-full px-4 py-3 border-0 focus:ring-0 text-sm text-stone-700 leading-relaxed resize-none bg-white",
            data: {
              paste_image_target: "editor",
              action: "paste->paste-image#handlePaste dragover->paste-image#handleDragOver drop->paste-image#handleDrop"
            } %>
      <div class="flex items-center justify-between px-3 py-2 border-t border-stone-100 bg-stone-50">
        <label class="inline-flex items-center gap-1.5 text-xs text-stone-400 hover:text-stone-600 cursor-pointer transition-colors">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          插入图片
          <input type="file" class="hidden" accept="image/*"
                 data-paste-image-target="fileInput"
                 data-action="change->paste-image#handleFileSelect">
        </label>
      </div>
    </div>

    <div class="flex flex-wrap items-end gap-4">
      <div class="flex-1 min-w-48">
        <%= f.label :tag_list, '标签', class: "block text-xs text-stone-400 mb-1" %>
        <%= f.text_field :tag_list,
              placeholder: "标签（可选）",
              class: "w-full text-sm bg-stone-50 border border-stone-200 rounded-md px-3 py-1.5 focus:outline-none focus:ring-1 focus:ring-amber-300 focus:border-amber-300 placeholder-stone-300 transition" %>
      </div>
      <div class="w-28">
        <%= f.label :status, '状态', class: "block text-xs text-stone-400 mb-1" %>
        <%= f.select :status,
              options_for_select([['草稿', 'draft'], ['发布', 'published']], @thought.status),
              {},
              class: "w-full text-sm bg-stone-50 border border-stone-200 rounded-md px-3 py-1.5 focus:outline-none focus:ring-1 focus:ring-amber-300 focus:border-amber-300 transition" %>
      </div>
    </div>

    <div class="flex items-center justify-end gap-3 pt-2">
      <%= link_to '取消', admin_thoughts_path,
            class: "text-sm text-stone-400 hover:text-stone-600 transition-colors" %>
      <%= f.submit '保存更改',
            class: "text-sm px-5 py-2 bg-stone-800 text-white rounded-full hover:bg-stone-700 cursor-pointer transition-colors" %>
    </div>
  <% end %>

</div>
