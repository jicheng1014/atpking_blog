<div class="max-w-2xl mx-auto px-4 sm:px-6 py-10">

  <div class="mb-10">
    <h1 class="text-xl font-semibold text-stone-900 mb-1">标签</h1>
    <p class="text-sm text-stone-400">按主题浏览所有文章</p>
  </div>

  <% if @tags.any? %>
    <div class="flex flex-wrap gap-3">
      <% @tags.each do |tag| %>
        <%= link_to tag_path(tag),
              class: "group inline-flex items-center gap-2 px-4 py-2 bg-white border border-stone-200 rounded-full text-sm text-stone-600 hover:border-amber-300 hover:text-amber-700 hover:bg-amber-50 transition-colors" do %>
          <span class="font-medium"><%= tag.name %></span>
          <span class="text-xs text-stone-300 group-hover:text-amber-400 transition-colors"><%= tag.posts_count %></span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-stone-400">暂无标签</p>
  <% end %>

</div>
